/* pages/rewards/rewards.wxss — 熏衣草主题 */
.page {
  padding-bottom: 32rpx;
}

.user-info {
  margin-top: 16rpx;
}

.user-header {
  margin-bottom: 32rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 32rpx;
  border: 4rpx solid var(--lavender-pale);
}

.user-details {
  justify-content: center;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--lavender-dark);
  margin-bottom: 8rpx;
}

.user-level {
  font-size: 28rpx;
  color: var(--lavender-mid);
  font-weight: bold;
}

.user-stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--lavender-mid);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.progress-bar {
  margin-top: 16rpx;
}

/* 抽卡系统 */
.gacha-section {
  margin-top: 24rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--lavender-dark);
  display: block;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
  display: block;
  margin-top: 8rpx;
}

.gacha-options {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.gacha-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  border-radius: 16rpx;
  width: 40%;
  text-align: center;
  transition: all 0.3s ease;
}

.gacha-option:active {
  transform: scale(0.95);
}

.gacha-option.single {
  background-color: rgba(156, 123, 200, 0.1);
  border: 2rpx solid var(--lavender-mid);
}

.gacha-option.multi {
  background-color: rgba(124, 92, 180, 0.1);
  border: 2rpx solid var(--lavender-dark);
}

.gacha-cost {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.cost-value {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--lavender-dark);
}

.cost-unit {
  font-size: 24rpx;
  color: var(--text-light);
  margin-left: 4rpx;
}

.gacha-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--lavender-dark);
  margin-bottom: 8rpx;
}

.gacha-desc {
  font-size: 22rpx;
  color: var(--text-light);
}

.gacha-history {
  margin-top: 24rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--lavender-dark);
  display: block;
  margin-bottom: 16rpx;
}

.history-list {
  white-space: nowrap;
}

.history-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 32rpx;
}

.item-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 22rpx;
  color: var(--text-primary);
}

/* 背包 */
.inventory-section {
  margin-top: 24rpx;
}

.empty-inventory {
  text-align: center;
  padding: 48rpx;
  color: var(--text-light);
  font-size: 26rpx;
}

.inventory-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32rpx;
}

.inventory-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.item-icon-container {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 8rpx;
}

.item-icon {
  width: 100%;
  height: 100%;
}

.item-count {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: var(--danger-color);
  color: white;
  font-size: 20rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.item-name {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--lavender-dark);
  margin-bottom: 4rpx;
}

.item-rarity {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.item-rarity.common {
  background-color: #f0f0f0;
  color: #999;
}

.item-rarity.rare {
  background-color: rgba(156, 123, 200, 0.1);
  color: var(--lavender-mid);
}

.item-rarity.epic {
  background-color: rgba(124, 92, 180, 0.15);
  color: var(--lavender-dark);
}

.item-rarity.legendary {
  background-color: rgba(201, 180, 233, 0.3);
  color: #6B4E9A;
}

/* 自定义奖励 */
.custom-rewards-section {
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.empty-rewards {
  text-align: center;
  padding: 48rpx;
  color: var(--text-light);
  font-size: 26rpx;
}

.rewards-list {
  margin-top: 16rpx;
}

.reward-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.reward-item:last-child {
  border-bottom: none;
}

.reward-content {
  flex: 1;
  margin-right: 24rpx;
}

.reward-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.reward-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--lavender-dark);
}

.reward-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.reward-status.pending {
  background-color: rgba(201, 180, 233, 0.3);
  color: var(--lavender-dark);
}

.reward-status.completed {
  background-color: rgba(107, 175, 138, 0.15);
  color: var(--success-color);
}

.reward-condition {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  display: block;
}

.reward-description {
  font-size: 22rpx;
  color: var(--text-light);
  line-height: 1.4;
}

/* 抽卡结果 */
.gacha-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
}

.result-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.result-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--lavender-dark);
  margin-bottom: 8rpx;
}

.result-rarity {
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.result-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.5;
}

.result-loading {
  text-align: center;
  padding: 48rpx;
  color: var(--text-light);
}

/* 表单样式 */
.form-item {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  font-weight: bold;
  color: var(--lavender-dark);
  font-size: 26rpx;
}

.picker {
  border: 1rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  background: #FAFAFA;
}
