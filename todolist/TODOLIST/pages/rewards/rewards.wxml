<!-- pages/rewards/rewards.wxml -->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-info card">
    <view class="user-header flex-row">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-details flex-col">
        <text class="user-name">{{userInfo.nickName || '时光旅行者'}}</text>
        <text class="user-level">Lv.{{userLevel}}</text>
      </view>
    </view>
    <view class="user-stats">
      <view class="stat-item">
        <text class="stat-value">{{points}}</text>
        <text class="stat-label">积分</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{experience}}/{{nextLevelExp}}</text>
        <text class="stat-label">经验</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{totalRewards}}</text>
        <text class="stat-label">累计奖励</text>
      </view>
    </view>
    <view class="progress-bar">
      <progress percent="{{levelProgress}}" stroke-width="8" active-color="#9C7BC8" />
    </view>
  </view>

  <!-- 抽卡系统 -->
  <view class="gacha-section card">
    <view class="section-header">
      <text class="section-title">幸运抽卡</text>
      <text class="section-subtitle">消耗积分抽取道具和皮肤</text>
    </view>
    <view class="gacha-options">
      <view class="gacha-option single" bindtap="drawGacha" data-type="single">
        <view class="gacha-cost">
          <text class="cost-value">100</text>
          <text class="cost-unit">积分</text>
        </view>
        <text class="gacha-name">单次抽卡</text>
        <text class="gacha-desc">获得随机道具</text>
      </view>
      <view class="gacha-option multi" bindtap="drawGacha" data-type="multi">
        <view class="gacha-cost">
          <text class="cost-value">900</text>
          <text class="cost-unit">积分</text>
        </view>
        <text class="gacha-name">十连抽</text>
        <text class="gacha-desc">必得稀有道具</text>
      </view>
    </view>
    <view class="gacha-history">
      <text class="history-title">最近获得</text>
      <scroll-view class="history-list" scroll-x>
        <view wx:for="{{recentItems}}" wx:key="id" class="history-item">
          <image class="item-icon" src="{{item.icon}}" mode="aspectFit"></image>
          <text class="item-name">{{item.name}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 背包/道具列表 -->
  <view class="inventory-section card">
    <view class="section-header">
      <text class="section-title">我的背包</text>
      <text class="section-subtitle">共 {{inventory.length}} 件道具</text>
    </view>
    <view wx:if="{{inventory.length === 0}}" class="empty-inventory">
      <text>背包空空如也，快去抽卡吧！</text>
    </view>
    <view wx:else class="inventory-grid">
      <view wx:for="{{inventory}}" wx:key="id" class="inventory-item" data-index="{{index}}" bindtap="useItem">
        <view class="item-icon-container">
          <image class="item-icon" src="{{item.icon}}" mode="aspectFit"></image>
          <text wx:if="{{item.count > 1}}" class="item-count">x{{item.count}}</text>
        </view>
        <text class="item-name">{{item.name}}</text>
        <text class="item-rarity {{item.rarity}}">{{item.rarityText}}</text>
      </view>
    </view>
  </view>

  <!-- 自定义奖励 -->
  <view class="custom-rewards-section card">
    <view class="section-header">
      <text class="section-title">自定义奖励</text>
      <button class="btn btn-secondary" size="mini" bindtap="showRewardModal">+ 新增</button>
    </view>
    <view wx:if="{{customRewards.length === 0}}" class="empty-rewards">
      <text>暂无自定义奖励，点击上方按钮创建</text>
    </view>
    <view wx:else class="rewards-list">
      <view wx:for="{{customRewards}}" wx:key="id" class="reward-item">
        <view class="reward-content">
          <view class="reward-header">
            <text class="reward-title">{{item.title}}</text>
            <text class="reward-status {{item.completed ? 'completed' : 'pending'}}">
              {{item.completed ? '已领取' : '待完成'}}
            </text>
          </view>
          <text class="reward-condition">条件: {{item.condition}}</text>
          <text class="reward-description">{{item.description}}</text>
        </view>
        <button class="btn btn-primary" size="mini" disabled="{{item.completed}}" bindtap="claimReward" data-id="{{item.id}}">领取</button>
      </view>
    </view>
  </view>

  <!-- 抽卡结果模态框 -->
  <modal title="抽卡结果" visible="{{gachaResultVisible}}" bindcancel="hideGachaResult" bindconfirm="hideGachaResult">
    <view slot="content" class="gacha-result">
      <view wx:if="{{gachaResult}}" class="result-item">
        <image class="result-icon" src="{{gachaResult.icon}}" mode="aspectFit"></image>
        <text class="result-name">{{gachaResult.name}}</text>
        <text class="result-rarity {{gachaResult.rarity}}">{{gachaResult.rarityText}}</text>
        <text class="result-desc">{{gachaResult.description}}</text>
      </view>
      <view wx:else class="result-loading">
        <text>正在抽卡中...</text>
      </view>
    </view>
  </modal>

  <!-- 新增自定义奖励模态框 -->
  <modal title="新增自定义奖励" visible="{{rewardModalVisible}}" bindcancel="hideRewardModal" bindconfirm="saveReward">
    <form slot="content">
      <view class="form-item">
        <text class="label">奖励标题</text>
        <input class="input" value="{{rewardForm.title}}" placeholder="例如：奖励自己一杯奶茶" bindinput="onRewardTitleInput" />
      </view>
      <view class="form-item">
        <text class="label">触发条件</text>
        <picker mode="selector" range="{{conditionOptions}}" value="{{rewardForm.conditionIndex}}" bindchange="onConditionChange">
          <view class="picker">{{conditionOptions[rewardForm.conditionIndex]}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="label">条件参数</text>
        <input class="input" type="number" value="{{rewardForm.conditionValue}}" placeholder="例如：10" bindinput="onConditionValueInput" />
      </view>
      <view class="form-item">
        <text class="label">奖励描述</text>
        <textarea class="input" value="{{rewardForm.description}}" placeholder="描述奖励内容和意义" bindinput="onRewardDescInput" />
      </view>
    </form>
  </modal>
</view>