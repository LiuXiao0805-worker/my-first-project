<!-- pages/settings/settings.wxml -->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-section card">
    <view class="user-header flex-row">
      <view class="avatar-container" bindtap="changeAvatar">
        <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="avatar-overlay">
          <text class="icon">📷</text>
        </view>
      </view>
      <view class="user-details flex-col">
        <input class="user-name-input" value="{{userInfo.nickName}}" placeholder="请输入昵称" maxlength="20"
               bindinput="onNickNameInput" bindblur="saveUserInfo" />
        <text class="user-id">ID: {{userId}}</text>
      </view>
    </view>
  </view>

  <!-- 外观设置 -->
  <view class="appearance-section card">
    <view class="section-title">外观设置</view>
    <view class="setting-item">
      <view class="setting-label">主题模式</view>
      <view class="setting-control">
        <radio-group bindchange="onThemeChange">
          <label class="radio-option">
            <radio value="light" checked="{{theme === 'light'}}" />
            <text>浅色</text>
          </label>
          <label class="radio-option">
            <radio value="dark" checked="{{theme === 'dark'}}" />
            <text>深色</text>
          </label>
          <label class="radio-option">
            <radio value="auto" checked="{{theme === 'auto'}}" />
            <text>跟随系统</text>
          </label>
        </radio-group>
      </view>
    </view>
    <view class="setting-item">
      <view class="setting-label">字体大小</view>
      <view class="setting-control">
        <slider value="{{fontSize}}" min="12" max="20" step="2" show-value bindchange="onFontSizeChange" />
      </view>
    </view>
  </view>

  <!-- 通知设置 -->
  <view class="notification-section card">
    <view class="section-title">通知设置</view>
    <view class="setting-item">
      <view class="setting-label">专注提醒</view>
      <switch checked="{{notifications.focus}}" bindchange="onFocusNotificationChange" />
    </view>
    <view class="setting-item">
      <view class="setting-label">任务到期</view>
      <switch checked="{{notifications.taskDue}}" bindchange="onTaskDueNotificationChange" />
    </view>
    <view class="setting-item">
      <view class="setting-label">好友互动</view>
      <switch checked="{{notifications.friend}}" bindchange="onFriendNotificationChange" />
    </view>
    <view class="setting-item">
      <view class="setting-label">团队消息</view>
      <switch checked="{{notifications.team}}" bindchange="onTeamNotificationChange" />
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="data-section card">
    <view class="section-title">数据管理</view>
    <view class="setting-item" bindtap="clearCache">
      <view class="setting-label">清理缓存</view>
      <view class="setting-control">
        <text class="cache-size">{{cacheSize}}</text>
        <text class="icon">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="exportData">
      <view class="setting-label">导出数据</view>
      <view class="setting-control">
        <text class="icon">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="importData">
      <view class="setting-label">导入数据</view>
      <view class="setting-control">
        <text class="icon">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="syncData">
      <view class="setting-label">立即同步</view>
      <view class="setting-control">
        <text class="sync-status {{syncStatus}}">{{syncStatusText}}</text>
      </view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="about-section card">
    <view class="section-title">关于</view>
    <view class="setting-item" bindtap="viewVersion">
      <view class="setting-label">版本</view>
      <view class="setting-control">
        <text class="version">{{version}}</text>
        <text class="icon">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="viewPrivacy">
      <view class="setting-label">隐私政策</view>
      <view class="setting-control">
        <text class="icon">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="viewTerms">
      <view class="setting-label">用户协议</view>
      <view class="setting-control">
        <text class="icon">›</text>
      </view>
    </view>
    <view class="setting-item" bindtap="contactSupport">
      <view class="setting-label">联系客服</view>
      <view class="setting-control">
        <text class="icon">›</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <button class="btn btn-primary" bindtap="saveAllSettings">保存设置</button>
    <button class="btn btn-danger mt-16" bindtap="logout">退出登录</button>
  </view>
</view>