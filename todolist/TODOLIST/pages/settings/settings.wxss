/* pages/settings/settings.wxss — 熏衣草主题 */
.page {
  padding-bottom: 32rpx;
}

.user-section {
  margin-top: 16rpx;
}

.user-header {
  align-items: center;
}

.avatar-container {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-right: 32rpx;
}

.user-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid var(--lavender-pale);
}

.avatar-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.avatar-container:active .avatar-overlay {
  opacity: 1;
}

.avatar-overlay .icon {
  font-size: 32rpx;
  color: white;
}

.user-details {
  flex: 1;
}

.user-name-input {
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  padding: 0;
  margin-bottom: 8rpx;
  color: var(--lavender-dark);
}

.user-id {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 设置项通用样式 */
.card {
  margin-top: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--lavender-dark);
  margin-bottom: 24rpx;
  display: block;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

.setting-control {
  display: flex;
  align-items: center;
}

/* 单选组样式 */
.radio-option {
  margin-left: 32rpx;
  display: flex;
  align-items: center;
}

.radio-option text {
  margin-left: 8rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}

/* 滑块样式 */
.setting-control slider {
  width: 300rpx;
}

/* 缓存大小 */
.cache-size {
  font-size: 26rpx;
  color: var(--text-light);
  margin-right: 16rpx;
}

/* 同步状态 */
.sync-status {
  font-size: 26rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.sync-status.success {
  background-color: rgba(107, 175, 138, 0.15);
  color: var(--success-color);
}

.sync-status.failed {
  background-color: rgba(250, 81, 81, 0.1);
  color: var(--danger-color);
}

.sync-status.pending {
  background-color: rgba(201, 180, 233, 0.3);
  color: var(--lavender-dark);
}

/* 版本号 */
.version {
  font-size: 26rpx;
  color: var(--text-light);
  margin-right: 16rpx;
}

/* 图标 */
.icon {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 操作按钮 */
.action-section {
  padding: 32rpx;
}

.action-section button {
  height: 80rpx;
  line-height: 80rpx;
}
